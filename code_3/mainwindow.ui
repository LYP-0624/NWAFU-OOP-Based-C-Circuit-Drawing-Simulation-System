      <property name="styleSheet">
       <string notr="true">/* 默认按钮长相：圆角、淡灰底色、精致边框 */
QPushButton {
    background-color: #f8f9fa;
    border: 1px solid #ced4da;
    border-radius: 6px;
    padding: 8px 12px;
    color: #495057;
    font-weight: bold;
    font-family: &quot;Microsoft YaHei&quot;;
}

/* 鼠标路过时的魔法：变成科技蓝底色，边框发光 */
QPushButton:hover {
    background-color: #e2eafc;
    border: 1px solid #abc4ff;
    color: #1d3557;
}

/* 鼠标按下去的瞬间：颜色加深，体现物理按压感 */
QPushButton:pressed {
    background-color: #ccdbfd;
    border: 1px solid #7b9acc;
}</string>
